{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "Jwt": {
    "Issuer": "threadia",
    "Audience": "threadia",
    "SigningKey": "",
    "ExpiryMinutes": 720
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Outbox": {
    "PollingIntervalMs": 500,
    "BatchSize": 20
  },
  "EventBus": {
    "Provider": "InProcess"
  },
  "RabbitMq": {
    "ConnectionString": "amqp://guest:guest@localhost:5672/"
  },
  "Storage": {
    "Provider": "S3",
    "ServiceUrl": "http://localhost:9000",
    "AccessKey": "",
    "SecretKey": "",
    "Bucket": "threadia-attachments"
  },
  "WebPush": {
    "VapidSubject": "mailto:admin@example.com",
    "VapidPublicKey": "",
    "VapidPrivateKey": ""
  },
  "Otel": {
    "OtlpEndpoint": ""
  }
}
